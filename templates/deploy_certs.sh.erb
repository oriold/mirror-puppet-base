#!/usr/bin/env bash

local_datadir=<%= @local_datadir %>

if [ ! -d $local_datadir ]
then
    echo "Missing data directory, not sure what to do"
    exit 0
else
    if [ ! -d ${local_datadir}/certs ]
    then
	echo "Missing certs directory, better leave"
	exit 0
    fi
fi

doas rsync -avz -i /home/backups/.ssh/id_ed25519 --rsync-path='doas rsync' backups@<%= @cert_source %>:<%= @cert_dir %>/ ${local_datadir}/certs/
